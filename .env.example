# ===========================================
# 环境变量配置示例
# ===========================================
# 复制此文件为 .env.local 并填写实际值
# 注意：.env.local 不会被提交到 Git

# ===========================================
# JWT 密钥（必须配置，用于用户认证）
# ===========================================
# 强烈建议使用至少 32 字符的随机字符串
# 可使用以下命令生成: openssl rand -base64 32
JWT_SECRET=your-secure-jwt-secret-at-least-32-characters

# ===========================================
# 默认 API 配置（JSON 格式）
# ===========================================
# 当数据库中没有配置时，将使用此环境变量作为默认配置
# 此配置包含真实的 API Key，请勿提交到 Git
#
# 配置结构说明：
# - textApis: 文本生成 API 配置列表
# - imageApis: 图片生成 API 配置列表
# - videoApis: 视频生成 API 配置列表
# - defaultTextApiId: 默认文本 API ID
# - defaultImageApiId: 默认图片 API ID
# - defaultVideoApiId: 默认视频 API ID
#
# 每个配置项包含：
# - id: 唯一标识
# - name: 显示名称
# - type: 类型 (text/image/video)
# - apiKey: API 密钥
# - baseUrl: API 基础 URL
# - model: 使用的模型
# - isDefault: 是否为默认
# - defaultAspectRatio: 默认宽高比（图片/视频）
# - defaultResolution: 默认分辨率（图片）
DEFAULT_API_CONFIGS={"textApis":[{"id":"yunwu-text-default","name":"云雾 Gemini 3.1 Pro","type":"text","apiKey":"your-text-api-key","baseUrl":"https://yunwu.ai/v1beta","model":"gemini-3.1-pro-preview","isDefault":true}],"imageApis":[{"id":"grsai-nanobanana-2","name":"NanoBanana 2","type":"image","apiKey":"your-image-api-key","baseUrl":"https://grsaiapi.com","model":"nano-banana-2","defaultAspectRatio":"1:1","defaultResolution":"1K","isDefault":true}],"videoApis":[{"id":"yunwu-video-veo31","name":"首尾帧","type":"video","apiKey":"your-video-api-key","baseUrl":"https://yunwu.ai","model":"veo_3_1","defaultAspectRatio":"9:16","isDefault":true}],"defaultTextApiId":"yunwu-text-default","defaultImageApiId":"grsai-nanobanana-2","defaultVideoApiId":"yunwu-video-veo31"}

# ===========================================
# 数据库配置（PostgreSQL / Supabase）
# ===========================================
# 说明：登录接口会优先使用 PGDATABASE_URL 进行数据库查询
PGDATABASE_URL=postgresql://username:password@localhost:5432/avatop
SUPABASE_URL=your-supabase-project-url
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# ===========================================
# 对象存储配置（S3 兼容）
# ===========================================
S3_ACCESS_KEY=your-s3-access-key
S3_SECRET_KEY=your-s3-secret-key
S3_BUCKET=your-bucket-name
S3_REGION=auto
S3_ENDPOINT=your-s3-endpoint

# ===========================================
# 服务配置
# ===========================================
# 服务端口（默认 5000）
DEPLOY_RUN_PORT=5000

# 环境标识（DEV 或 PROD）
COZE_PROJECT_ENV=DEV

# 对外访问域名
COZE_PROJECT_DOMAIN_DEFAULT=http://localhost:5000

# ===========================================
# Video download provider
# ===========================================
# auto: TikTok/Douyin use TikHub first, then yt-dlp fallback; other platforms use yt-dlp
# 推荐在后台「模型设置 -> 下载解析」中配置 TikHub API Key；以下 TikHub 环境变量仅作为数据库未配置时的兜底。
VIDEO_DOWNLOAD_PROVIDER=auto
TIKHUB_BASE_URL=https://api.tikhub.io
TIKHUB_API_KEY=your-tikhub-api-key
